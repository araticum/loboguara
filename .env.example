# Core
APP_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventsaas
REDIS_URL=redis://localhost:6379/0
SERIEMA_DB_SCHEMA=seriema
SERIEMA_REDIS_DB=5
SERIEMA_REDIS_KEY_PREFIX=seriema
SERIEMA_QUEUE_PREFIX=queue:seriema

# Security / Ops
SERIEMA_ADMIN_TOKEN=change-me
VOICE_WEBHOOK_SECRET=change-me
VOICE_WEBHOOK_MAX_AGE_SECONDS=300
SERIEMA_OPS_MAX_LIMIT=100

# Voice provider
VOICE_PROVIDER=signalwire
VOICE_TWIML_MODE=prerecorded
VOICE_PRERECORDED_AUDIO_URL=https://cdn.example.com/incident-alert.mp3
SIGNALWIRE_SPACE_URL=your-space.signalwire.com
SIGNALWIRE_PROJECT_ID=your_signalwire_project_id
SIGNALWIRE_API_TOKEN=your_signalwire_api_token
SIGNALWIRE_FROM_NUMBER=+5511000000000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Worker reliability
SERIEMA_TASK_MAX_RETRIES=5
SERIEMA_TASK_RETRY_BACKOFF=2
SERIEMA_TASK_RETRY_BACKOFF_MAX=60
SERIEMA_TASK_RETRY_JITTER=true
SERIEMA_TASK_SOFT_TIME_LIMIT=30
SERIEMA_TASK_TIME_LIMIT=45

# DLQ / Metrics
SERIEMA_DLQ_QUEUE_NAME=dlq
SERIEMA_DLQ_REPLAY_BATCH_SIZE=10
SERIEMA_DLQ_MAX_ITEMS=1000
SERIEMA_DLQ_REPLAY_DRY_RUN=false
SERIEMA_DLQ_REPLAY_LOCK_TTL_SECONDS=60
SERIEMA_METRICS_KEY=metrics:ops
SERIEMA_METRICS_TTL_SECONDS=120
SERIEMA_METRICS_SNAPSHOT_INTERVAL_SECONDS=60
SERIEMA_DLQ_REPLAY_INTERVAL_SECONDS=120
SERIEMA_DLQ_PRUNE_INTERVAL_SECONDS=300
SERIEMA_INCIDENT_STALE_MINUTES=30
SERIEMA_INCIDENT_STALE_SWEEP_INTERVAL_SECONDS=120

